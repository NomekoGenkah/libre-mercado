# ===========================================================================
#  Libre Mercado — variables de entorno (TEMPLATE)
#  Copia este archivo a `.env` y rellena los valores reales.
#  El archivo `.env` está en .gitignore y NUNCA debe commitearse.
# ===========================================================================

# --- Credenciales root de MariaDB (todas las instancias) -------------------
MARIADB_ROOT_PASSWORD=changeme_root

# --- Nodo Central (tablas globales) ----------------------------------------
CENTRAL_DB=lm_central
CENTRAL_USER=lm_user
CENTRAL_PASSWORD=changeme_central

# --- Sucursal Norte --------------------------------------------------------
NORTE_DB=lm_norte
NORTE_USER=lm_user
NORTE_PASSWORD=changeme_norte

# --- Sucursal Sur ----------------------------------------------------------
SUR_DB=lm_sur
SUR_USER=lm_user
SUR_PASSWORD=changeme_sur

# --- Sucursal Este ---------------------------------------------------------
ESTE_DB=lm_este
ESTE_USER=lm_user
ESTE_PASSWORD=changeme_este

# ===========================================================================
#  Variables que consume el contenedor PHP (hosts internos = nombres de
#  servicio en la red `red_distribuida`). El puerto interno de cada MariaDB
#  siempre es 3306; los puertos externos se mapean en docker-compose.yml.
# ===========================================================================
DB_PORT=3306

CENTRAL_HOST=nodo_central
NORTE_HOST=nodo_sucursal_norte
SUR_HOST=nodo_sucursal_sur
ESTE_HOST=nodo_sucursal_este

# Origen permitido por CORS (solo si consumes la API desde otro origen;
# la consola PHP+AJAX es mismo origen y no lo necesita)
CORS_ORIGIN=http://localhost:5173
